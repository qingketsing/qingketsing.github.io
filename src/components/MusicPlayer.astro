---
interface Props {
  audioSrc?: string;
  coverSrc?: string;
  title?: string;
  artist?: string;
}

const { audioSrc, coverSrc, title, artist } = Astro.props;

// 获取站点URL用于构建绝对路径
const siteUrl = Astro.site?.href || '';
const basePath = import.meta.env.BASE_URL || '/';

// 构建绝对路径的辅助函数
function buildAbsolutePath(path: string): string {
  if (!path) return '';
  if (path.startsWith('http')) return path; // 已经是绝对URL
  if (path.startsWith('/')) {
    // 如果是GitHub Pages部署，需要添加完整的域名
    if (siteUrl && !siteUrl.includes('localhost')) {
      return siteUrl.replace(/\/$/, '') + path;
    }
    return path;
  }
  return path;
}

// 设置默认值并构建绝对路径
const finalAudioSrc = buildAbsolutePath(audioSrc || '/8_31.mp3');
const finalCoverSrc = buildAbsolutePath(coverSrc || '/yorushika.jpg');
const finalTitle = title || '8/31';
const finalArtist = artist || 'Yorushika';
---

<style>
        .wave {
            animation: wave 1.5s linear infinite;
        }
        @keyframes wave {
            0%, 100% { transform: scaleY(1); }
            50% { transform: scaleY(1.8); }
        }
        .wave:nth-child(2) { animation-delay: 0.2s; }
        .wave:nth-child(3) { animation-delay: 0.4s; }
        .wave:nth-child(4) { animation-delay: 0.6s; }
        
        .player-popup {
            transition: all 0.3s ease;
            opacity: 0;
            transform: translateY(10px);
            pointer-events: none;
        }
        .player-popup.show {
            opacity: 1;
            transform: translateY(0);
            pointer-events: all;
        }
    </style>
<!-- 固定定位容器 -->
<audio id="audio-player" src={finalAudioSrc}></audio>
    
    <!-- 耳机入口按钮 -->
    <div class="fixed bottom-8 right-8 z-50">
        <button id="player-toggle" class="bg-indigo-600 hover:bg-indigo-700 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
            </svg>
            <i class="fas fa-headphones text-xl"></i>
        </button>
        
        <!-- 悬浮播放器 -->
        <div id="player-popup" class="player-popup absolute bottom-full right-0 mb-4 w-72 bg-white rounded-xl shadow-2xl overflow-hidden">
            <!-- 封面和歌曲信息 -->
            <div class="relative">
                <img src={finalCoverSrc} alt="专辑封面" class="w-full h-40 object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 right-4">
                    <h3 class="text-white font-bold text-lg truncate">{finalTitle}</h3>
                    <p class="text-gray-300 text-sm truncate">{finalArtist}</p>
                </div>
            </div>
            
            <!-- 进度条 -->
            <div class="px-4 py-3">
                <div class="flex justify-between text-xs text-gray-500 mb-1">
                    <span id="current-time">0:00</span>
                    <span id="duration">0:00</span>
                </div>
                <div class="h-1.5 bg-gray-200 rounded-full cursor-pointer relative" id="progress-container">
                    <!-- 缓冲进度条 -->
                    <div class="h-1.5 bg-gray-300 rounded-full absolute inset-0" id="buffer-bar" style="width: 0%"></div>
                    <!-- 播放进度条 -->
                    <div class="h-1.5 bg-indigo-500 rounded-full relative z-10" id="progress-bar" style="width: 0%">
                        <div class="absolute right-0 -top-0.5 w-3 h-3 bg-white rounded-full shadow"></div>
                    </div>
                </div>
            </div>
            
            <!-- 控制按钮 -->
            <div class="flex items-center justify-between px-4 py-3">
                <button class="text-gray-500 hover:text-indigo-600" id="prev-btn">
                    <i class="fas fa-step-backward"></i>
                </button>
                
                <button class="play-btn bg-indigo-600 hover:bg-indigo-700 text-white rounded-full w-10 h-10 flex items-center justify-center" id="play-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
                    </svg>

                    <i class="fas fa-play"></i>
                </button>
                
                <button class="text-gray-500 hover:text-indigo-600" id="next-btn">
                    <i class="fas fa-step-forward"></i>
                </button>
                
                <div class="flex items-center ml-2">
                    <button class="text-gray-500 hover:text-indigo-600 mr-1" id="volume-btn">
                        <i class="fas fa-volume-up text-sm"></i>
                    </button>
                    <div class="w-16 h-1 bg-gray-200 rounded-full cursor-pointer" id="volume-container">
                        <div class="h-1 bg-indigo-500 rounded-full" id="volume-bar" style="width: 80%"></div>
                    </div>
                </div>
            </div>
            
            <!-- 音波动画 -->
            <div class="px-4 pb-3 flex justify-center">
                <div class="flex space-x-1 items-end h-6" id="wave-container">
                    <div class="wave w-1 h-2 bg-indigo-400 rounded-full"></div>
                    <div class="wave w-1 h-3 bg-indigo-400 rounded-full"></div>
                    <div class="wave w-1 h-4 bg-indigo-400 rounded-full"></div>
                    <div class="wave w-1 h-2 bg-indigo-400 rounded-full"></div>
                    <div class="wave w-1 h-3 bg-indigo-400 rounded-full"></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 获取音频元素
        const audioPlayer = document.getElementById('audio-player') as HTMLAudioElement;
        
        // 播放器状态
        const playerState = {
            isPlaying: false,
            currentTime: 0,
            duration: 0, // 将从音频文件动态获取
            volume: 1.0,
            lastVolume: 0.5,
            isMetadataLoaded: false,
            isCanPlay: false
        };
        
        // DOM 元素
        const playerToggle = document.getElementById('player-toggle');
        const playerPopup = document.getElementById('player-popup');
        const playBtn = document.getElementById('play-btn');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const volumeBtn = document.getElementById('volume-btn');
        const volumeContainer = document.getElementById('volume-container');
        const volumeBar = document.getElementById('volume-bar');
        const progressContainer = document.getElementById('progress-container');
        const progressBar = document.getElementById('progress-bar');
        const bufferBar = document.getElementById('buffer-bar');
        const currentTimeEl = document.getElementById('current-time');
        const durationEl = document.getElementById('duration');
        const waveContainer = document.getElementById('wave-container');
        const waves = document.querySelectorAll('.wave');
        
        // 检查音频元素是否存在
        if (!audioPlayer) {
            console.error('音频播放器元素未找到');
        } else {
            // 初始化音频设置
            audioPlayer.volume = playerState.volume;
            audioPlayer.preload = 'metadata';
            
            // 初始显示
            if (durationEl) {
                durationEl.textContent = '加载中...';
            }
            
            // 音频加载状态监听
            audioPlayer.addEventListener('loadstart', () => {
                console.log('开始加载音频');
                if (durationEl) {
                    durationEl.textContent = '加载中...';
                }
            });
            
            // 音频元数据加载完成
            audioPlayer.addEventListener('loadedmetadata', () => {
                console.log('音频元数据加载完成');
                playerState.duration = audioPlayer.duration;
                playerState.isMetadataLoaded = true;
                
                if (durationEl && !isNaN(audioPlayer.duration) && audioPlayer.duration > 0) {
                    durationEl.textContent = formatTime(playerState.duration);
                    console.log('音频时长:', playerState.duration, '秒 (' + formatTime(playerState.duration) + ')');
                } else {
                    durationEl.textContent = '未知';
                    console.warn('无法获取音频时长');
                }
            });
            
            // 音频数据加载完成，可以播放
            audioPlayer.addEventListener('loadeddata', () => {
                console.log('音频数据加载完成');
                // 如果元数据还没加载，这里再试一次获取时长
                if (!playerState.isMetadataLoaded && audioPlayer.duration && !isNaN(audioPlayer.duration)) {
                    playerState.duration = audioPlayer.duration;
                    playerState.isMetadataLoaded = true;
                    if (durationEl) {
                        durationEl.textContent = formatTime(playerState.duration);
                    }
                    console.log('从loadeddata获取音频时长:', playerState.duration, '秒');
                }
            });
            
            // 音频可以播放时
            audioPlayer.addEventListener('canplay', () => {
                console.log('音频可以播放');
                playerState.isCanPlay = true;
                
                // 最后一次尝试获取时长
                if (!playerState.isMetadataLoaded && audioPlayer.duration && !isNaN(audioPlayer.duration)) {
                    playerState.duration = audioPlayer.duration;
                    playerState.isMetadataLoaded = true;
                    if (durationEl) {
                        durationEl.textContent = formatTime(playerState.duration);
                    }
                    console.log('从canplay获取音频时长:', playerState.duration, '秒');
                }
            });
            
            // 音频时长改变事件（某些浏览器会触发）
            audioPlayer.addEventListener('durationchange', () => {
                console.log('音频时长发生改变');
                if (audioPlayer.duration && !isNaN(audioPlayer.duration) && audioPlayer.duration > 0) {
                    playerState.duration = audioPlayer.duration;
                    playerState.isMetadataLoaded = true;
                    if (durationEl) {
                        durationEl.textContent = formatTime(playerState.duration);
                    }
                    console.log('从durationchange获取音频时长:', playerState.duration, '秒');
                }
            });
            
            // 音频加载错误处理
            audioPlayer.addEventListener('error', (e) => {
                console.error('音频加载失败:', e);
                console.error('音频源:', audioPlayer.src);
                console.error('错误详情:', audioPlayer.error);
                
                if (durationEl) {
                    durationEl.textContent = '加载失败';
                }
                
                // 根据错误类型显示不同信息
                if (audioPlayer.error) {
                    switch (audioPlayer.error.code) {
                        case 1: // MEDIA_ERR_ABORTED
                            console.error('音频加载被中止');
                            break;
                        case 2: // MEDIA_ERR_NETWORK
                            console.error('网络错误导致音频加载失败');
                            break;
                        case 3: // MEDIA_ERR_DECODE
                            console.error('音频解码失败');
                            break;
                        case 4: // MEDIA_ERR_SRC_NOT_SUPPORTED
                            console.error('音频格式不支持');
                            break;
                        default:
                            console.error('未知音频错误');
                    }
                }
            });
            
            // 进度更新事件
            audioPlayer.addEventListener('progress', () => {
                // 更新缓冲进度条
                if (audioPlayer.buffered.length > 0 && playerState.duration > 0) {
                    const buffered = (audioPlayer.buffered.end(0) / playerState.duration) * 100;
                    if (bufferBar) {
                        bufferBar.style.width = `${Math.min(buffered, 100)}%`;
                    }
                    console.log('缓冲进度:', buffered.toFixed(1) + '%');
                }
            });
        }
        
        // 音频时间更新事件
        audioPlayer.addEventListener('timeupdate', () => {
            playerState.currentTime = audioPlayer.currentTime;
            
            // 更新当前时间显示
            if (currentTimeEl) {
                currentTimeEl.textContent = formatTime(playerState.currentTime);
            }
            
            // 更新进度条（只有当时长有效时才更新）
            if (playerState.duration > 0 && progressBar) {
                const percent = (playerState.currentTime / playerState.duration) * 100;
                progressBar.style.width = `${Math.min(percent, 100)}%`;
            }
            
            // 如果时长还没有获取到，尝试再次获取
            if (playerState.duration <= 0 && audioPlayer.duration && !isNaN(audioPlayer.duration)) {
                playerState.duration = audioPlayer.duration;
                if (durationEl) {
                    durationEl.textContent = formatTime(playerState.duration);
                }
                console.log('从timeupdate获取音频时长:', playerState.duration, '秒');
            }
        });
        
        // 音频播放结束事件
        audioPlayer.addEventListener('ended', () => {
            playerState.isPlaying = false;
            const playButton = playBtn?.querySelector('i');
            if (playButton) {
                playButton.classList.remove('fa-pause');
                playButton.classList.add('fa-play');
            }
            
            // 停止音波动画
            waves.forEach(wave => {
                (wave as HTMLElement).style.animationPlayState = 'paused';
            });
        });
        
        // 切换播放器显示/隐藏
        playerToggle?.addEventListener('click', (e) => {
            e.stopPropagation();
            playerPopup?.classList.toggle('show');
        });
        
        // 点击页面其他地方关闭播放器
        document.addEventListener('click', () => {
            playerPopup?.classList.remove('show');
        });
        
        // 阻止播放器内部点击事件冒泡
        playerPopup?.addEventListener('click', (e) => {
            e.stopPropagation();
        });
        
        // 播放/暂停
        playBtn?.addEventListener('click', () => {
            // 检查音频是否准备就绪
            if (!playerState.isCanPlay) {
                console.warn('音频还未准备好播放');
                // 尝试强制加载
                audioPlayer.load();
                return;
            }
            
            playerState.isPlaying = !playerState.isPlaying;
            
            const icon = playBtn.querySelector('i');
            if (icon) {
                icon.classList.toggle('fa-pause');
                icon.classList.toggle('fa-play');
            }
            
            // 控制音波动画
            waves.forEach(wave => {
                if(playerState.isPlaying) {
                    (wave as HTMLElement).style.animationPlayState = 'running';
                } else {
                    (wave as HTMLElement).style.animationPlayState = 'paused';
                }
            });
            
            // 控制音频播放
            if(playerState.isPlaying) {
                const playPromise = audioPlayer.play();
                
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        console.log('音频播放成功');
                        // 播放成功后再次尝试获取时长
                        if (!playerState.isMetadataLoaded && audioPlayer.duration && !isNaN(audioPlayer.duration)) {
                            playerState.duration = audioPlayer.duration;
                            playerState.isMetadataLoaded = true;
                            if (durationEl) {
                                durationEl.textContent = formatTime(playerState.duration);
                            }
                            console.log('播放时获取音频时长:', playerState.duration, '秒');
                        }
                    }).catch(error => {
                        console.error('播放失败:', error);
                        playerState.isPlaying = false;
                        if (icon) {
                            icon.classList.remove('fa-pause');
                            icon.classList.add('fa-play');
                        }
                        // 停止音波动画
                        waves.forEach(wave => {
                            (wave as HTMLElement).style.animationPlayState = 'paused';
                        });
                    });
                }
            } else {
                audioPlayer.pause();
            }
        });
        
        // 上一曲 (示例功能，需要你有多个音频文件)
        prevBtn?.addEventListener('click', () => {
            // 这里可以添加播放列表和切换上一曲的逻辑
            console.log('上一曲');
        });
        
        // 下一曲 (示例功能，需要你有多个音频文件)
        nextBtn?.addEventListener('click', () => {
            // 这里可以添加播放列表和切换下一曲的逻辑
            console.log('下一曲');
        });
        
        // 音量控制
        volumeContainer?.addEventListener('click', (e: MouseEvent) => {
            const width = volumeContainer.clientWidth;
            const clickX = e.offsetX;
            const volume = clickX / width;
            
            playerState.volume = Math.max(0, Math.min(1, volume));
            if (volumeBar) {
                volumeBar.style.width = `${playerState.volume * 100}%`;
            }
            audioPlayer.volume = playerState.volume;
            
            // 更新音量图标
            updateVolumeIcon();
        });
        
        // 进度条控制
        progressContainer?.addEventListener('click', (e: MouseEvent) => {
            // 只有当音频时长有效时才允许跳转
            if (playerState.duration <= 0 || !playerState.isMetadataLoaded) {
                console.warn('音频时长未获取，无法跳转');
                return;
            }
            
            const rect = progressContainer.getBoundingClientRect();
            const clickX = e.clientX - rect.left;
            const width = rect.width;
            const percent = Math.max(0, Math.min(1, clickX / width));
            
            const newTime = percent * playerState.duration;
            playerState.currentTime = newTime;
            audioPlayer.currentTime = newTime;
            
            // 立即更新显示
            if (progressBar) {
                progressBar.style.width = `${percent * 100}%`;
            }
            if (currentTimeEl) {
                currentTimeEl.textContent = formatTime(newTime);
            }
            
            console.log(`跳转到: ${formatTime(newTime)} (${(percent * 100).toFixed(1)}%)`);
        });
        
        // 静音/取消静音
        volumeBtn?.addEventListener('click', () => {
            if(playerState.volume > 0) {
                playerState.lastVolume = playerState.volume;
                playerState.volume = 0;
            } else {
                playerState.volume = playerState.lastVolume || 0.5;
            }
            
            if (volumeBar) {
                volumeBar.style.width = `${playerState.volume * 100}%`;
            }
            audioPlayer.volume = playerState.volume;
            updateVolumeIcon();
        });
        
        // 更新音量图标
        function updateVolumeIcon() {
            const icon = volumeBtn?.querySelector('i');
            
            if(icon) {
                if(playerState.volume === 0) {
                    icon.classList.remove('fa-volume-up', 'fa-volume-down');
                    icon.classList.add('fa-volume-mute');
                } else if(playerState.volume < 0.5) {
                    icon.classList.remove('fa-volume-up', 'fa-volume-mute');
                    icon.classList.add('fa-volume-down');
                } else {
                    icon.classList.remove('fa-volume-down', 'fa-volume-mute');
                    icon.classList.add('fa-volume-up');
                }
            }
        }
        
        // 格式化时间 (秒 -> MM:SS)
        function formatTime(seconds: number): string {
            if (!seconds || isNaN(seconds) || seconds < 0) {
                return '0:00';
            }
            
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs < 10 ? '0' : ''}${secs}`;
        }
        
        // 强制刷新音频时长的辅助函数
        function refreshAudioDuration(): void {
            if (audioPlayer && audioPlayer.duration && !isNaN(audioPlayer.duration) && audioPlayer.duration > 0) {
                playerState.duration = audioPlayer.duration;
                playerState.isMetadataLoaded = true;
                if (durationEl) {
                    durationEl.textContent = formatTime(playerState.duration);
                }
                console.log('刷新音频时长:', playerState.duration, '秒');
                return;
            }
            
            // 如果还是获取不到，尝试重新加载
            console.log('尝试重新加载音频以获取时长');
            audioPlayer.load();
        }
        
        // 定时检查音频时长（备用机制）
        let durationCheckCount = 0;
        const maxDurationChecks = 20; // 最多检查20次
        const durationCheckInterval = setInterval(() => {
            durationCheckCount++;
            
            if (playerState.isMetadataLoaded || durationCheckCount >= maxDurationChecks) {
                clearInterval(durationCheckInterval);
                if (!playerState.isMetadataLoaded) {
                    console.warn('音频时长获取超时，可能是网络或文件问题');
                    if (durationEl) {
                        durationEl.textContent = '时长未知';
                    }
                }
                return;
            }
            
            if (audioPlayer.readyState >= 1) { // HAVE_METADATA
                refreshAudioDuration();
            }
        }, 500); // 每500ms检查一次
        
        // 初始化
        updateVolumeIcon();
    </script>