---
import 'leaflet/dist/leaflet.css';

const allPosts = await Astro.glob('./posts/*.md');
// 处理数据：提取 frontmatter、添加文章链接，并按时间排序
const latestPosts = allPosts
  .map(post => ({
    ...post.frontmatter,
    url: post.url,
  })).sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate)).slice(0, 5);

