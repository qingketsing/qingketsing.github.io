---
const { frontmatter } = Astro.props;
import MusicPlayer from "../components/MusicPlayer.astro";

// 从frontmatter中提取音乐配置
const musicConfig = frontmatter.music;
const shouldShowPlayer = musicConfig && musicConfig.audioSrc;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{frontmatter.title}</title>
    <link href="/output.css" rel="stylesheet">
    <!-- KaTeX CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.4/dist/katex.min.css" integrity="sha384-vKruj+a13U8yHIkAyGgK1J3ArTLzrFGBbBc0tDp4ad/EyewESeXE/Iv67Aj8gKZ0" crossorigin="anonymous">
    <style>
        /* 增加换行标签的间距 */
        .prose br {
            display: block;
            margin-top: 1.5em;
            margin-bottom: 1.5em;
            content: "";
        }
        
        /* 段落首行缩进2个字符 */
        .prose p {
            text-indent: 2em;
            margin-bottom: 1.5em;
        }
        
        /* 处理<br>后的内容缩进 */
        .prose br + * {
            text-indent: 2em;
        }
        
        /* 增加列表项之间的间距 */
        .prose li {
            margin-bottom: 0.75em;
        }
        
        /* 列表内的段落不需要缩进 */
        .prose li p {
            text-indent: 0;
        }
        
        /* 增加标题与段落之间的间距 */
        .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
            margin-top: 2.5em;
            margin-bottom: 1.5em;
        }
        
        /* 第一个标题的上边距不需要太大 */
        .prose h1:first-child, .prose h2:first-child, .prose h3:first-child {
            margin-top: 0;
        }
        
        /* 引用块内的段落不需要缩进 */
        .prose blockquote p {
            text-indent: 0;
        }
        
        /* KaTeX 数学公式样式 */
        .prose .katex {
            font-size: 1.1em;
        }
        
        /* 行内数学公式 */
        .prose .katex-inline {
            font-size: inherit;
        }
        
        /* 块级数学公式 */
        .prose .katex-display {
            margin: 2em 0;
            text-align: center;
        }
        
        /* 数学公式不需要缩进 */
        .prose .katex-display,
        .prose .katex {
            text-indent: 0;
        }
    </style>
    
</head>

<body class="bg-gray-50 bg-cover bg-no-repeat bg-fixed">
    <!-- 只有当文章配置了音乐时才显示播放器 -->
    {shouldShowPlayer && (
        <div class="fixed bottom-8 right-8 z-[9999]">
            <MusicPlayer 
                audioSrc={musicConfig.audioSrc}
                coverSrc={musicConfig.coverSrc}
                title={musicConfig.title}
                artist={musicConfig.artist}
            />
        </div>
    )}
    <div class="pl-5 pt-5 font-bold text-xl text-gray-400 grid grid-cols-10 items-center">
        <div class="text-gray-400 col-span-1 text-center col-start-1">Qingke</div>
        <div class="text-gray-400 col-span-1 text-center col-start-3 hover:text-gray-500 flex items-center gap-2"> <!-- 新增 flex 布局 -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 flex-none">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            <a href="/" class="">首页</a>
        </div>

        <div class="text-gray-400 col-span-1 text-center col-start-4 hover:text-gray-500 flex items-center gap-2"> <!-- 新增 flex 布局 -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 flex-none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
            <a href="/latest" class="">博客</a>
        </div>
        <div class="text-gray-400 col-span-1 text-center col-start-5 hover:text-gray-500 flex items-center gap-2"> <!-- 新增 flex 布局 -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 flex-none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
            <a href="/" class="">项目</a>
        </div>
        <div class="text-gray-400 col-span-1 text-center col-start-6 hover:text-gray-500 flex items-center gap-2"> <!-- 新增 flex 布局 -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 flex-none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
            <a href="/" class="">友链</a>
        </div>
        <div class="text-gray-400 col-span-1 text-center col-start-7 hover:text-gray-500 flex items-center gap-2"> <!-- 新增 flex 布局 -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 flex-none">
                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
            </svg>
            <a href="/about" class="">关于</a>
        </div>
    </div>
    
    <div class="h-[250px] pl-[5%]">
        <div class="pt-[100px]"></div>
        <h1 class="text-4xl font-bold pl-[60px] text-black">{frontmatter.title}</h1>
        <div class="pt-5 xl:pt-5"></div>
        <h1 class="text-xl font-bold pl-[60px] text-black">更新于:{frontmatter.pubDate}</h1>     
        <div class="pt-[20px] xl:pt-15"></div>
        <!--生成一个绿色的分割线 -->
        <div class="pt-[10px]">
            <div class="w-[70%] h-[4px] bg-green-500 ml-[60px]"></div>
        </div>
    </div>

    <div class="flex flex-col md:flex-row w-full max-w-[1400px] mx-auto pt-10">
  <!-- 左侧内容区 -->
  <div class="w-full md:w-[70%] px-4 md:px-8">
    <div class="bg-blue-100 rounded-lg bg-opacity-40">
      <div class="pt-10"></div>
      <div class="px-6 pt-5 prose prose-lg max-w-none text-gray-900">
        <slot />
      </div>
      <div class="pt-10"></div>
    </div>
  </div>
  <!-- 右侧头像区 -->
  <aside class="hidden md:block w-[30%] pl-4">
    <div class="flex flex-col items-center border-2 border-gray-300 rounded-lg bg-white bg-opacity-80 mt-12 w-[300px] mx-auto p-6 shadow-lg">
      <div class="pt-5"></div>
      <img class="w-32 h-32 md:w-52 md:h-52 rounded-full mx-auto" src="/My_pic.jpg" alt="Qingke">
      <div class="pt-10"></div>
      <h1 class="text-2xl font-bold text-center text-gray-800">Qingke</h1>
      <div class="pt-1 xl:pt-3"></div>
      <p class="text-lg text-center text-gray-700">/*我们在地板上睡过*/</p>
      <p class="text-lg text-center text-gray-700">/*我们在河水中淌过*/</p>
      <div class="pt-5"></div>
      <div class="text-xl text-center bg-gray-100 h-[30px] rounded-lg text-black">
        文章分区 : {frontmatter.type}
      </div>
      <div class="pt-5"></div>
      <div class="flex space-x-2">
        <a href="https://github.com/qingketsing" class="w-14 h-14 rounded-lg">
          <img src="/github-box.png" alt="">
        </a>
        <a href="https://space.bilibili.com/548020217" class="w-14 h-14 rounded-lg">
          <img src="/哔哩哔哩.png" alt="">
        </a>
        <a href="https://www.zhihu.com/people/qing-ke-tsing" class="w-14 h-14 rounded-lg">
          <img src="/知乎.png" alt="">
        </a>
        <a href="https://music.163.com/#/user/home?id=12216179252" class="w-14 h-14 rounded-lg">
          <img src="/网易云音乐.png" alt="">
        </a>
      </div>
    </div>
  </aside>
</div>
    <div class="pt-32"></div>
    
    <!-- KaTeX JS -->
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.4/dist/katex.min.js" integrity="sha384-PwRUT/YqbnEjkZO0zZxNqcxACrXe+j766U2amXcgMg5457rve2Y7I6ZJSm2A0mS4" crossorigin="anonymous"></script>
    <!-- KaTeX auto-render -->
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.4/dist/contrib/auto-render.min.js" integrity="sha384-+VBxd3r6XgURycqtZ117nYw44OOcIax56Z4dCRWbxyPt0Koah1uHoK0o4+/RRE05" crossorigin="anonymous" onload="renderMathInElement(document.body);"></script>
    
    <!-- KaTeX 自动渲染脚本 -->
    <script is:inline>
        document.addEventListener("DOMContentLoaded", function() {
            // 多重保险渲染方式
            function renderMath() {
                if (window.renderMathInElement) {
                    try {
                        renderMathInElement(document.body, {
                            delimiters: [
                                {left: '$$', right: '$$', display: true},
                                {left: '$', right: '$', display: false}
                            ],
                            throwOnError: false
                        });
                        console.log('KaTeX渲染成功');
                    } catch (e) {
                        console.error('KaTeX渲染失败:', e);
                    }
                } else {
                    setTimeout(renderMath, 100);
                }
            }
            
            // 延迟执行
            setTimeout(renderMath, 500);
        });
    </script>
            
</body>
</html>
